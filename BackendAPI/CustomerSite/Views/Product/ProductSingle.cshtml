@using ShareView.DTO
@{
    ViewData["Title"] = "Product Page";
    Layout = "~/Views/Shared/_Layout_Slider.cshtml";
    var mh = ViewBag.screen as ScreenDTO;
    var bxl = ViewBag.processor as ProcessorDTO;
    var ram = ViewBag.ram as RamDTO;
}

<section class="bg-light pt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="">
                    <img src="https://localhost:7123/wwwroot/@Model.Image" class="card-img-top" alt="..." />
                </div>
            </div>
            <div class="col-lg-6">
                <div class="col">
                    <h5 class="fs-2 fw-semibold">
                        @Model.NameProduct
                    </h5>
                    <div class="mt-5">
                        <div class="d-flex align-items-center">
                            <div class="fs-5 fw-bold me-5">Rating</div>
                            <div class="">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= @Model.Rating)
                                    {
                                        <i class="fa-regular fa-star checked"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-star"></i>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="d-flex align-items-center">
                            <div class="fs-5 fw-bold me-5">Remaining</div>
                            <div class="">
                                <span>@Model.Quantity</span>
                            </div>
                        </div>
                    </div>
                    <p class="mt-3 fs-3 fw-semibold">@Model.Price.ToString("#,##0 VND")</p>
                    <form class="col-md-6 d-flex mb-3" asp-controller="Cart" asp-action="AddToCartQuantity" method="post">
                        <div style="display:none">
                            <input id="id" name="id" value="@Model.ProductId" />
                        </div>
                        <span class="me-2">
                            <button type="button"
                                    class="button-quantity btn-minus"
                                    data-type="minus"
                                    data-field="">
                                <i class="fa-solid fa-minus"></i>
                            </button>
                        </span>
                        <input type="number"
                               id="quantity"
                               name="quantity"
                               class="form-control w-25 text-center"
                               value="1"
                               min="1"
                               max="@Model.Quantity" />
                        <span class="ms-2">
                            <button type="button"
                                    class="button-quantity btn-plus"
                                    data-type="plus"
                                    data-field="">
                                <i class="fa-solid fa-plus"></i>
                            </button>
                        </span>
                        @{
                            if (@Model.Quantity == 0)
                            {
                                    <button type="submit" class="btn btn-primary ms-5 w-100 disabled">
                                        Buy Now
                                    </button>
                            }
                            else
                            {
                                    <button type="submit" class="btn btn-primary ms-5 w-100">
                                        Buy Now
                                    </button>
                            }
                         }
                    </form>
                    <button type="button" class="btn ms-5 w-50 btn-warning" data-bs-toggle="modal" data-bs-target="#exampleModal">
                        Rating
                    </button>
                </div>
            </div>
        </div>
        <div class="detail mt-5">
            <table class="mb-0 table table-hover text-center">
                <thead class="table-secondary p-5">
                    <tr>
                        <th class="fw-bold fs-3" colspan="2">Processor</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="p-3">
                        <th scope="row">CPU Technology</th>
                        <td>@bxl.CPUTechnology</td>
                    </tr>
                    <tr class="p-3">
                        <th scope="row">Cores</th>
                        <td>@bxl.Thread</td>
                    </tr>
                    <tr>
                        <th scope="row">Threads</th>
                        <td>@bxl.Multiplier</td>
                    </tr>
                    <tr class="p-3">
                        <th scope="row">CPU Speed</th>
                        <td>@bxl.Speed</td>
                    </tr>
                    <tr class="p-3">
                        <th scope="row">Maximum Speed</th>
                        <td>@bxl.MaxSpeed</td>
                    </tr>
                    <tr class="p-3">
                        <th scope="row">Cache</th>
                        <td>@bxl.Cache</td>
                    </tr>
                </tbody>
            </table>
            <table class="table table-hover text-center mb-0">
                <thead class="table-secondary">
                    <tr class="p-3">
                        <th class="fw-bold fs-3" colspan="2">Screen</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="p-3">
                        <th scope="row">Size</th>
                        <td scope="row">@mh.Size</td>
                    </tr>
                </tbody>
            </table>
            <table class="table table-hover text-center mb-0">
                <thead class="table-secondary">
                    <tr class="p-3">
                        <th class="fw-bold fs-3" colspan="2">RAM</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="p-3">
                        <th scope="row">RAM</th>
                        <td>@ram.Capacity</td>
                    </tr>
                    <tr class="p-3">
                        <th scope="row">RAM Type</th>
                        <td>@ram.Typee</td>
                    </tr>
                    <tr class="p-3">
                        <th scope="row">RAM Bus Speed</th>
                        <td>@ram.BusRam</td>
                    </tr>
                    <tr class="p-3">
                        <th scope="row">Maximum RAM Support</th>
                        <td>@ram.MaxSupport</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <table class="table table-hover text-center mb-0 mt-5">
            <thead class="table-secondary">
                <tr class="p-3">
                    <th class="fw-bold fs-3" colspan="3">Comments</th>
                </tr>
            </thead>
            <tbody >
                <tr class="table-secondary">
                    <th>User Email</th>
                    <th>Comments</th>
                    <th>Rating</th>
                </tr>
                @foreach (var item in Model.Ratings)
                {
                    <tr class="p-3">
                        <th scope="row">@item.Customer.Email</th>
                        <td>@item.Comments</td>
                        <td>
                            <div class="">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= @item.Rate)
                                    {
                                        <i class="fa-regular fa-star checked"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-star"></i>
                                    }
                                }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>


<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
@*        <div class="modal-content">*@
        <form class="modal-content needs-validation" asp-controller="Product" asp-action="Rating" method="post" novalidate>
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Product Review</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @*<form class=" needs-validation" asp-controller="Product" asp-action="Rating" method="post" novalidate>*@
                    <div class="d-flex justify-content-between">
                        <span>Rating star</span>
                        <div>
                            <i class="ratingStar fa-regular fa-star" data-value="1"></i>
                            <i class="ratingStar fa-regular fa-star" data-value="2"></i>
                            <i class="ratingStar fa-regular fa-star" data-value="3"></i>
                            <i class="ratingStar fa-regular fa-star" data-value="4"></i>
                            <i class="ratingStar fa-regular fa-star" data-value="5"></i>
                        </div>
                    </div>
                    <div>
                        <input type="hidden" name="ratingsValue" id="ratingsValue" />
                        <input type="hidden" name="ProductId" id="ProductId" value="@Model.ProductId" />
                        <input type="text"
                               id="comment"
                               name="comment"
                               class="form-control w-100"
                               required />
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">Rating</button>
            </div>
@*        </div>*@
        </form>
    </div>
</div>
